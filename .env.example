# ── Supabase ──────────────────────────────────────────────────────────────────
# Direct Postgres connection string (asyncpg).
# Use session-mode pooler (port 5432) — transaction mode breaks asyncpg prepared statements.
# Format: postgresql://postgres.PROJECTREF:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_DB_URL=postgresql://postgres.PROJECTREF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate ONCE with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: Rotating this key makes ALL encrypted API keys in the DB permanently unreadable.
# Store in Railway secret vars, never commit to git.
FERNET_KEY=your_base64_url_safe_32_byte_key_here

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO
# PORT is injected automatically by Railway — do not set manually in production

# ── Skill retrieval (2000+ skills catalog) ────────────────────────────────────
# Platform-level embedding key used to pick the most relevant enabled skills
# for each incoming message. If unset, skill selection falls back to
# pinned + newest enabled skills (no vector search) — the app still works.
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_API_KEY=
# Max skill snippets injected into the system prompt per message
MAX_SKILLS_IN_PROMPT=5

# ── Skill seeding (one-off script: python -m aipa.scripts.generate_skills) ────
# SEED_API_KEY / SEED_MODEL are read from the shell env, not this file.

# ── Webhook registration ───────────────────────────────────────────────────────
# Set to your Render public URL (e.g. https://aipa.onrender.com)
# Used by POST /webhook/telegram/{token}/setup-webhook to build the webhook URL.
# If unset, falls back to the request's base URL (works behind Render's proxy).
BASE_URL=https://aipa.onrender.com
